# ----------------------------------------------------------------------
# 1. Dependency Directories
# ----------------------------------------------------------------------
node_modules/
# In case using pnpm
.pnpm-store/

# ----------------------------------------------------------------------
# 2. Environment Variables & Secrets (CRITICAL FOR PUBLIC REPOS)
# ----------------------------------------------------------------------
# Ignore all .env files in root and ALL subdirectories
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# EXCEPT: Do allow the example file (so other devs know what keys are needed)
!/**/.env.example
!/**/.env.sample
!.env.example
!.env.sample

# Ignore other local secrets
*.pem
*.key
*.cert

# ----------------------------------------------------------------------
# 3. SQLite Databases
# ----------------------------------------------------------------------
# Ignore actual DB files
*.sqlite
*.sqlite3
*.db
*.db3
*.s3db
*.sl3

# Ignore SQLite temporary/journal files
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*-journal
*-shm
*-wal

# ----------------------------------------------------------------------
# 4. Build & Production Outputs
# ----------------------------------------------------------------------
# Standard build folders
dist/
dist-ssr/
build/
out/
_site/

# Next.js specific
.next/

# ----------------------------------------------------------------------
# 5. Logs and Debugging
# ----------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log.*

# ----------------------------------------------------------------------
# 6. Testing & Coverage
# ----------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
cypress/videos/
cypress/screenshots/
playwright-report/

# ----------------------------------------------------------------------
# 7. Editor & OS Files (Junk)
# ----------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace
# Keep the user's specific exclusion if they want to track extensions
# !.vscode/extensions.json 

# JetBrains / IntelliJ
.idea/
*.iws
*.iml
*.ipr

# Mac / Windows / Linux
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# ----------------------------------------------------------------------
# 8. Misc / Tooling
# ----------------------------------------------------------------------
# AI Coding tools
.aider*

# Local Netlify/Vercel folders
.netlify/
.vercel/

# TypeScript build info
*.tsbuildinfo

# Local History extensions
.history/